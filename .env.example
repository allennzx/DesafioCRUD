# ─── Configurações do Banco de Dados ─────────────────────────────────────────
# Copie este arquivo para .env e preencha com suas credenciais reais
# O arquivo .env NÃO deve ser commitado no Git

# URL de conexão JDBC com o MySQL
# Formato: jdbc:mysql://<host>:<porta>/<nome_do_banco>?opcoes
DB_URL=jdbc:mysql://localhost:3306/crud_db?useSSL=false&serverTimezone=America/Sao_Paulo&allowPublicKeyRetrieval=true

# Usuário do MySQL
DB_USER=root

# Senha do MySQL
DB_PASSWORD=sua_senha_aqui
